import java.util.*;

public class SecureLoginSystem {

    static Scanner sc = new Scanner(System.in);

    static String storedUsername = "KRITHI1605";
    static String storedPassword = "Krithi@1605";

    static int generateOTP() {
        Random random = new Random();
        return 1000 + random.nextInt(9000);
    }

    static boolean login(String username, String password) {
        return username.equals(storedUsername) && password.equals(storedPassword);
    }

    public static void main(String[] args) {

        System.out.println("===== Secure Login System with OTP/MFA =====");

        System.out.print("Enter username: ");
        String username = sc.nextLine();

        System.out.print("Enter password: ");
        String password = sc.nextLine();

        if (login(username, password)) {
            System.out.println("Username and password verified.");

            int otp = generateOTP();
            System.out.println("Generated OTP: " + otp);

            System.out.print("Enter OTP: ");
            int userOtp = sc.nextInt();

            if (userOtp == otp) {
                System.out.println("Login successful. MFA verification completed.");
            } else {
                System.out.println("Invalid OTP. Access denied.");
            }
        } else {
            System.out.println("Invalid username or password.");
        }

        sc.close();
    }
}
