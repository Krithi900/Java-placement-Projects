import java.util.*;
public class Railsystem {
	static int totalSeats = 10;
    static boolean[] seats = new boolean[totalSeats];

    static void bookSeat() {
        for (int i = 0; i < totalSeats; i++) {
            if (!seats[i]) {
                seats[i] = true;
                System.out.println("Seat booked successfully! Seat No: " + (i + 1));
                return;
            }
        }
        System.out.println("Sorry! No seats available.");
    }

    static void cancelSeat(int seatNo) {
        if (seatNo < 1 || seatNo > totalSeats) {
            System.out.println("Invalid seat number");
            return;
        }

        if (seats[seatNo - 1]) {
            seats[seatNo - 1] = false;
            System.out.println("Seat " + seatNo + " cancelled.");
        } else {
            System.out.println("Seat already empty.");
        }
    }

    static void viewSeats() {
        int booked = 0;
        for (boolean seat : seats) {
            if (seat) booked++;
        }
        System.out.println("Booked Seats: " + booked);
        System.out.println("Available Seats: " + (totalSeats - booked));
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1.Book 2.Cancel 3.View 4.Exit");
            int choice = sc.nextInt();

            switch (choice) {
                case 1: bookSeat(); break;
                case 2:
                    System.out.print("Enter seat number: ");
                    cancelSeat(sc.nextInt());
                    break;
                case 3: viewSeats(); break;
                case 4: return;
            }
        }
    }

}
